{
  "name": "selfie-board",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:party\"",
    "dev:client": "cd client && npm run dev",
    "dev:party": "npx partykit dev",
    "build": "cd client && npm run build",
    "deploy:party": "npx partykit deploy",
    "deploy": "cd client && vercel --prod"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "partykit": "^0.0.111"
  }
}
